{
  "name": "covid19",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "build:search": "bun run build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@fontsource/source-sans-pro": "^5.2.5",
    "@iconify-json/mdi": "^1.2.3",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.0",
    "astro-icon": "^1.1.5",
    "date-fns": "^4.4.0",
    "mdast-util-to-string": "^4.0.0",
    "pagefind": "^1.5.2",
    "reading-time": "^1.5.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/typography": "^0.5.20",
    "daisyui": "^5.5.23",
    "husky": "^9.1.7",
    "vitest": "^4.1.9"
  }
