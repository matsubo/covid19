---
import type { Covid19Entry } from "@/lib/handlers/covid19";
import ArticleCard from "./ArticleCard.astro";

type Props = {
  prefectureSlug: string;
  prefectureName: string;
  articles: Covid19Entry[];
  showAll?: boolean;
};

const { prefectureSlug, prefectureName, articles, showAll = false } = Astro.props;
const displayArticles = showAll ? articles : articles.slice(0, 6);
---

<section class="mb-12">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-3xl font-bold">{prefectureName}</h2>
    {!showAll && articles.length > 6 && (
      <a
        href={`/prefecture/${prefectureSlug}`}
        class="btn btn-outline btn-sm"
      >
        もっと見る ({articles.length}件)
      </a>
    )}
  </div>

  {displayArticles.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {displayArticles.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>
  ) : (
    <p class="text-gray-500 dark:text-gray-400 text-center py-8">
      グラフがありません
    </p>
  )}
</section>
