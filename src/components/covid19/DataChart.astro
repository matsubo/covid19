---
type Props = {
  src: string;
  alt: string;
  title?: string;
  width?: number;
  height?: number;
  loading?: "eager" | "lazy";
};

const {
  src,
  alt,
  title,
  width = 1200,
  height = 800,
  loading = "eager",
} = Astro.props;
---

<figure class="my-8">
  {title && (
    <div class="text-center mb-4">
      <h3 class="text-xl font-bold text-balance">{title}</h3>
    </div>
  )}
  <div class="rounded-lg overflow-hidden shadow-lg bg-white dark:bg-gray-800">
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      class="w-full h-auto"
      loading={loading}
      decoding="async"
      fetchpriority={loading === "eager" ? "high" : undefined}
    />
  </div>
  {alt && (
    <figcaption class="text-center text-sm text-gray-500 dark:text-gray-400 mt-2">
      {alt}
    </figcaption>
  )}
</figure>
