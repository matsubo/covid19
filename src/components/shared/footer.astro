---
import { NAVIGATION_LINKS, SOCIAL_LINKS, OTHER_LINKS } from "@/lib/config";
import Icon from "../bases/icon.astro";
import ThemeController from "../bases/theme-controller.astro";
---

<footer class="relative border-t border-gray-200 dark:border-gray-800 bg-gradient-to-b from-white to-gray-50 dark:from-gray-900 dark:to-gray-950 py-12">
  <div class="container mx-auto px-4">
    <!-- メインフッターコンテンツ -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
      
      <!-- サイト情報 -->
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-indigo-600 to-purple-600 dark:from-indigo-500 dark:to-purple-500 flex items-center justify-center shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-lg bg-gradient-to-r from-indigo-600 to-purple-600 dark:from-indigo-400 dark:to-purple-400 bg-clip-text text-transparent">
                        <a href="/" class=" ">
              COVID-19
            </a>
            </h3>
            <p class="text-xs text-gray-500 dark:text-gray-400">Data Visualization</p>
          </div>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
          各都道府県が提供しているオープンデータを視覚化し、新型コロナウイルスの感染状況を分かりやすくお届けします。
        </p>
      </div>

      <!-- ナビゲーション -->
      <div class="space-y-4">
        <h3 class="font-bold text-lg text-gray-900 dark:text-white flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          都道府県一覧
        </h3>
        <nav class="flex flex-col gap-3">

          {NAVIGATION_LINKS.map(({ href, text, target }) => (
            <a 
              href={href} 
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors duration-300 flex items-center gap-2 group" 
              target={target ?? "_self"}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              {text}
            </a>
          ))}
        </nav>
      </div>

      <!-- ソーシャルメディア -->
      <div class="space-y-4">
        <h3 class="font-bold text-lg text-gray-900 dark:text-white flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
          </svg>
          フォロー
        </h3>
        <div class="flex flex-wrap gap-3">
          {SOCIAL_LINKS.map(({ href, icon, text, target }) => (
            <a
              href={href}
              class="btn btn-circle btn-sm bg-gray-100 dark:bg-gray-800 hover:bg-gradient-to-br hover:from-indigo-600 hover:to-purple-600 dark:hover:from-indigo-500 dark:hover:to-purple-500 border-none hover:text-white transition-all duration-300 hover:scale-110 shadow-md hover:shadow-lg"
              target={target ?? "_blank"}
              title={text}
              aria-label={text}
            >
              <Icon icon={icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- 追加情報とテーマ切り替え -->
      <div class="space-y-4">
        <h3 class="font-bold text-lg text-gray-900 dark:text-white flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-pink-600 dark:text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          その他
        </h3>
        <nav class="flex flex-col gap-3">
          {OTHER_LINKS.map(({ href, text, target }) => (
            <a 
              href={href} 
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-purple-600 dark:hover:text-purple-400 transition-colors duration-300 flex items-center gap-2 group" 
              target={target ?? "_self"}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              {text}
            </a>
          ))}
        </nav>

        <!-- テーマ切り替え -->
        <div class="pt-4 border-t border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-3">
            <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">テーマ:</span>
            <ThemeController />
          </div>
        </div>
      </div>
    </div>

    <!-- 区切り線 -->
    <div class="h-px bg-gradient-to-r from-transparent via-gray-300 dark:via-gray-700 to-transparent my-8"></div>

    <!-- フッター下部 -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-600 dark:text-gray-400">
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
        <span>Made with care for public health</span>
      </div>
      <div class="flex items-center gap-2">
        <span>© {new Date().getFullYear()} COVID-19 Data Visualization</span>
        <span class="text-gray-400">|</span>
        <span class="text-xs bg-gradient-to-r from-indigo-600 to-purple-600 dark:from-indigo-400 dark:to-purple-400 bg-clip-text text-transparent font-semibold">
          Last updated: 2022/10
        </span>
      </div>
    </div>
  </div>

  <!-- 装飾的な背景要素 -->
  <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 opacity-50"></div>
</footer>
