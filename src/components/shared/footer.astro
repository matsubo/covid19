---
import { NAVIGATION_LINKS, SOCIAL_LINKS, OTHER_LINKS } from "@/lib/config";
import { Icon } from "astro-icon/components";
import ThemeController from "../bases/theme-controller.astro";
import { covid19Handler } from "@/lib/handlers/covid19";

// 都道府県ごとの記事件数を取得
const stats = await covid19Handler.statistics();
const countByPrefecture = new Map(
  stats.prefectureCount.map(({ prefecture, count }) => [prefecture, count])
);

// NAVIGATION_LINKSの都道府県名から都道府県識別子を取得するヘルパー
function getPrefectureId(href: string): string {
  return href.split('/').pop() || '';
}
---

<footer class="relative border-t border-gray-200 dark:border-gray-800 bg-gradient-to-b from-white to-gray-50 dark:from-gray-900 dark:to-gray-950 py-12">
  <div class="container mx-auto px-4">
    <!-- メインフッターコンテンツ -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
      
      <!-- サイト情報 -->
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-indigo-600 to-purple-600 dark:from-indigo-500 dark:to-purple-500 flex items-center justify-center shadow-lg">
            <Icon name="mdi:chart-bar" class="h-7 w-7 text-white" />
          </div>
          <div>
            <h3 class="font-bold text-lg bg-gradient-to-r from-indigo-600 to-purple-600 dark:from-indigo-400 dark:to-purple-400 bg-clip-text text-transparent">
                        <a href="/" class=" ">
              COVID-19
            </a>
            </h3>
            <p class="text-xs text-gray-500 dark:text-gray-400">Data Visualization</p>
          </div>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
          各都道府県が提供しているオープンデータを視覚化し、新型コロナウイルスの感染状況を分かりやすくお届けします。
        </p>
      </div>

      <!-- ナビゲーション -->
      <div class="space-y-4">
        <h3 class="font-bold text-lg text-gray-900 dark:text-white flex items-center gap-2">
          <Icon name="mdi:flash" class="h-5 w-5 text-indigo-600 dark:text-indigo-400" />
          都道府県一覧
        </h3>
        <nav class="flex flex-col gap-3">
          {NAVIGATION_LINKS.map(({ href, text, target }) => {
            const prefectureId = getPrefectureId(href);
            const count = countByPrefecture.get(prefectureId) || 0;

            return (
              <a
                href={href}
                class="text-sm text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors duration-300 flex items-center justify-between gap-2 group"
                target={target ?? "_self"}
              >
                <span class="flex items-center gap-2">
                  <Icon name="mdi:chevron-right" class="h-4 w-4 transform group-hover:translate-x-1 transition-transform duration-300" />
                  {text}
                </span>
                <span class="text-xs px-2 py-0.5 rounded-full bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 font-medium">
                  {count}
                </span>
              </a>
            );
          })}
        </nav>
      </div>

      <!-- ソーシャルメディア -->
      <div class="space-y-4">
        <h3 class="font-bold text-lg text-gray-900 dark:text-white flex items-center gap-2">
          <Icon name="mdi:chat" class="h-5 w-5 text-purple-600 dark:text-purple-400" />
          フォロー
        </h3>
        <nav class="flex flex-col gap-3">
          {SOCIAL_LINKS.map(({ href, text, target }) => (
            <a
              href={href} 
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-purple-600 dark:hover:text-purple-400 transition-colors duration-300 flex items-center gap-2 group" 
              target={target ?? "_self"}
            >
              <Icon name="mdi:chevron-right" class="h-4 w-4 transform group-hover:translate-x-1 transition-transform duration-300" />
              {text}
            </a>
          ))}

          <a href="https://www.buymeacoffee.com/matsubokkuri"><img src="https://img.buymeacoffee.com/button-api/?text=Buy me a coffee&emoji=&slug=matsubokkuri&button_colour=FFDD00&font_colour=000000&font_family=Comic&outline_colour=000000&coffee_colour=ffffff" alt="Buy me a coffee" /></a>
          
        </nav>
      </div>

      <!-- 追加情報とテーマ切り替え -->
      <div class="space-y-4">
        <h3 class="font-bold text-lg text-gray-900 dark:text-white flex items-center gap-2">
          <Icon name="mdi:information" class="h-5 w-5 text-pink-600 dark:text-pink-400" />
          その他
        </h3>
        <nav class="flex flex-col gap-3">
          {OTHER_LINKS.map(({ href, text, target }) => (
            <a 
              href={href} 
              class="text-sm text-gray-600 dark:text-gray-400 hover:text-purple-600 dark:hover:text-purple-400 transition-colors duration-300 flex items-center gap-2 group" 
              target={target ?? "_self"}
            >
              <Icon name="mdi:chevron-right" class="h-4 w-4 transform group-hover:translate-x-1 transition-transform duration-300" />
              {text}
            </a>
          ))}
        </nav>

        <!-- テーマ切り替え -->
        <div class="pt-4 border-t border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-3">
            <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">テーマ:</span>
            <ThemeController />
          </div>
        </div>
      </div>
    </div>

    <!-- 区切り線 -->
    <div class="h-px bg-gradient-to-r from-transparent via-gray-300 dark:via-gray-700 to-transparent my-8"></div>

    <!-- フッター下部 -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-600 dark:text-gray-400">
      <div class="flex items-center gap-2">
        <Icon name="mdi:heart" class="h-5 w-5 text-indigo-600 dark:text-indigo-400" />
        <span>Made with care for public health</span>
      </div>
      <div class="flex items-center gap-2">
        <span>© {new Date().getFullYear()} COVID-19 Data Visualization</span>
        <span class="text-gray-400">|</span>
        <span class="text-xs bg-gradient-to-r from-indigo-600 to-purple-600 dark:from-indigo-400 dark:to-purple-400 bg-clip-text text-transparent font-semibold">
          Last updated: 2022/10
        </span>
      </div>
    </div>
  </div>

  <!-- 装飾的な背景要素 -->
  <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 opacity-50"></div>
</footer>
