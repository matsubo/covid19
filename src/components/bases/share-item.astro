---
import { Icon } from 'astro-icon/components';

type Props = {
  className: string;
  title: string;
  dataAwSocialShare: string;
  dataAwUrl: string | URL;
  dataAwText: string;
  icon: "clipboard" | "facebook" | "linkedin" | "twitter" | "whatsapp";
};

const { className, title, dataAwSocialShare, dataAwUrl, dataAwText, icon } =
  Astro.props;

// Map social icons to MDI icon names
const iconMap = {
  clipboard: "mdi:clipboard-outline",
  facebook: "mdi:facebook",
  linkedin: "mdi:linkedin",
  twitter: "mdi:twitter",
  whatsapp: "mdi:whatsapp",
} as const;

const iconName = iconMap[icon];

// Pre-build class list for better performance
const buttonClasses = [
  "slide",
  "active:scale-95",
  "w-12",
  "h-12",
  "bg-base-200",
  "flex",
  "items-center",
  "justify-center",
  "rounded-xl",
  "overflow-hidden",
  "transition-all",
  "duration-300",
  "cursor-pointer",
  "dark:hover:text-base-content",
  "hover:text-accent-content",
  ...className.split(" ").filter(Boolean), // Filter out empty strings
];
---

<button
  class:list={buttonClasses}
  title={title}
  data-aw-social-share={dataAwSocialShare}
  data-aw-url={dataAwUrl}
  data-aw-text={dataAwText}
  type="button"
>
  <span class="shareIcon" aria-hidden="true">
    <Icon name={iconName} />
  </span>
</button>

<style>
  .slide:hover .shareIcon {
    animation: slide-in-top 0.3s both;
  }

  @keyframes slide-in-top {
    0% {
      transform: translateY(-50px);
      opacity: 0;
    }
    100% {
      transform: translateY(0);
      opacity: 1;
    }
  }
</style>
