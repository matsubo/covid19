---
import BaseLayout from "@/layouts/base.astro";
import ArticleCard from "@/components/covid19/ArticleCard.astro";
import Pagination from "@/components/shared/pagination.astro";
import { covid19Handler } from "@/lib/handlers/covid19";
import { SITE } from "@/lib/config";

export async function getStaticPaths() {
  const allArticles = await covid19Handler.allArticles();
  const totalPages = Math.ceil(allArticles.length / SITE.postsPerPage);
  const paths = [];

  for (let i = 1; i <= totalPages; i++) {
    const start = (i - 1) * SITE.postsPerPage;
    const end = start + SITE.postsPerPage;

    paths.push({
      params: {
        page: i.toString(),
      },
      props: {
        articles: allArticles.slice(start, end),
        currentPage: i,
        totalPages,
        totalArticles: allArticles.length,
      },
    });
  }

  return paths;
}

const { articles, currentPage, totalPages, totalArticles } = Astro.props;

// メタ情報
const meta = {
  title: "すべてのグラフ - 新型コロナウイルス新規陽性者数の遷移グラフ",
  description: `新型コロナウイルス新規陽性者数の推移グラフ一覧（全${totalArticles}件）`,
  type: "website" as const,
};

// ページネーション用の情報
const baseUrl = "/archives";
const currentUrl = `/archives/${currentPage}`;
const prevUrl = currentPage > 1 ? `/archives/${currentPage - 1}` : undefined;
const nextUrl = currentPage < totalPages ? `/archives/${currentPage + 1}` : undefined;
const lastUrl = `/archives/${totalPages}`;
---

<BaseLayout entry={{ meta }}>
  <div class="container mx-auto px-4 py-12">
    <!-- ヘッダー -->
    <header class="mb-12 text-center">
      <nav class="breadcrumbs text-sm mb-4 justify-center">
        <ul>
          <li><a href="/">ホーム</a></li>
          <li>すべてのグラフ</li>
        </ul>
      </nav>
      <h1 class="text-5xl font-bold mb-4">すべてのグラフ</h1>
      <p class="text-xl text-gray-600 dark:text-gray-300">
        新型コロナウイルス新規陽性者数の推移グラフ
      </p>
      <p class="text-lg mt-2">
        全{totalArticles}件のグラフ (ページ {currentPage} / {totalPages})
      </p>
    </header>

    <!-- 記事一覧 -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {articles.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>

    <!-- ページネーション -->
    <Pagination
      length={totalPages}
      currentUrl={currentUrl}
      currentPage={currentPage}
      baseUrl={baseUrl}
      prevUrl={prevUrl}
      nextUrl={nextUrl}
      lastUrl={lastUrl}
    />
  </div>
</BaseLayout>
