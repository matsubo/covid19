---
import Layout from "@/layouts/base.astro";
import type { Meta } from "@/lib/types";
import { SITE } from "@/lib/config";

const meta: Meta = {
  title: `検索 | ${SITE.title}`,
  metaTitle: `検索 - ${SITE.title}`,
  description: "COVID-19関連のグラフや都道府県データを検索",
  type: "website",
  ogImage: "/images/default-image.jpg",
  ogImageAlt: "検索ページ",
};

const entry = {
  meta,
};
---

<Layout entry={entry}>
  <main class="w-full px-4 py-8">
    <h1 class="text-3xl font-bold mb-8">サイト内検索</h1>
    <div id="search"></div>
  </main>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    // PagefindUIが利用可能になるまで待つ
    function waitForPagefind() {
      if (typeof PagefindUI !== 'undefined') {
        initPagefind();
      } else {
        setTimeout(waitForPagefind, 50);
      }
    }
    
    function initPagefind() {
      new PagefindUI({
        element: "#search",
        showSubResults: true,
        autofocus: true,
        translations: {
          placeholder: "検索...",
          clear_search: "クリア",
          load_more: "さらに読み込む",
          search_label: "このサイトを検索",
          filters_label: "フィルター",
          zero_results: "[SEARCH_TERM] の検索結果が見つかりませんでした",
          many_results: "[SEARCH_TERM] の検索結果 [COUNT] 件",
          one_result: "[SEARCH_TERM] の検索結果 [COUNT] 件",
          alt_search: "[SEARCH_TERM] の検索結果が見つかりませんでした。代わりに [DIFFERENT_TERM] の検索結果を表示します",
          search_suggestion: "[SEARCH_TERM] の検索結果が見つかりませんでした。次のいずれかの検索をお試しください:",
          searching: "検索中...",
        },
      });

      const el = document.querySelector(".pagefind-ui");
      const input = el?.querySelector('input[type="text"]');
      const clearButton = el?.querySelector(".pagefind-ui__search-clear");

      // URLのクエリパラメータから検索語を取得
      const url = new URL(window.location.href);
      const params = new URLSearchParams(url.search);
      const query = params.get("q");

      // ページ読み込み時にクエリが存在する場合
      if (query && input) {
        input.value = query;
        input.dispatchEvent(new Event("input", { bubbles: true }));
      }

      // 入力時にURLのクエリパラメータを更新
      input?.addEventListener("input", (e) => {
        const target = e.target;
        const url = new URL(window.location.href);
        const params = new URLSearchParams(url.search);
        params.set("q", target.value);
        window.history.replaceState({}, "", `${url.pathname}?${params}`);
      });

      // クリアボタンクリック時にクエリパラメータを削除
      clearButton?.addEventListener("click", () => {
        const url = new URL(window.location.href);
        const params = new URLSearchParams(url.search);
        params.delete("q");
        window.history.replaceState({}, "", `${url.pathname}`);
      });
    }
    
    // ページ読み込み後に初期化を開始
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', waitForPagefind);
    } else {
      waitForPagefind();
    }
  </script>
</Layout>
