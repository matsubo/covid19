---
import Layout from "@/layouts/base.astro";
import type { Meta } from "@/lib/types";
import { SITE } from "@/lib/config";
import { Icon } from 'astro-icon/components';

const meta: Meta = {
  title: `検索 | ${SITE.title}`,
  metaTitle: `検索 - ${SITE.title}`,
  description: "COVID-19関連のグラフや都道府県データを検索",
  type: "website",
  ogImage: "/images/default-image.jpg",
  ogImageAlt: "検索ページ",
};

const entry = {
  meta,
};
---

<Layout entry={entry}>
  <main class="w-full px-4 py-8 max-w-4xl mx-auto min-h-screen">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">サイト内検索</h1>
      <p class="text-gray-600 dark:text-gray-400">COVID-19関連の記事を検索できます</p>
    </div>

    <!-- 検索ボックス -->
    <div class="mb-8">
      <div class="relative">
        <input
          type="text"
          id="search-input"
          placeholder="キーワードを入力..."
          class="w-full px-4 py-3 pl-12 pr-12 text-base border-2 border-gray-300 dark:border-gray-600 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400"
        />
        <Icon name="mdi:magnify" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 dark:text-gray-500" />
        <button
          id="clear-button"
          class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 hidden"
          aria-label="クリア"
        >
          <Icon name="mdi:close" class="w-5 h-5" />
        </button>
      </div>
    </div>

    <!-- 検索状態メッセージ -->
    <div id="search-status" class="mb-4 text-sm text-gray-600 dark:text-gray-400 hidden"></div>

    <!-- 検索結果 -->
    <div id="search-results" class="space-y-4"></div>

    <!-- 初期状態メッセージ -->
    <div id="initial-message" class="text-center py-12 text-gray-500 dark:text-gray-400">
      <Icon name="mdi:magnify" class="w-16 h-16 mx-auto mb-4 text-gray-300 dark:text-gray-600" />
      <p class="text-lg">キーワードを入力して検索してください</p>
    </div>

    <!-- エラーメッセージ -->
    <div id="error-message" class="hidden p-6 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg">
      <p class="text-yellow-800 dark:text-yellow-200 mb-2"><strong>検索機能が利用できません</strong></p>
      <p class="text-sm text-yellow-700 dark:text-yellow-300">検索機能を使用するには、まずサイトをビルドする必要があります。</p>
      <pre class="mt-2 p-2 bg-yellow-100 dark:bg-yellow-900/40 rounded text-xs">bun run build</pre>
    </div>
  </main>

  <script type="module">
    function handlePagefindError() {
      document.getElementById('error-message')?.classList.remove('hidden');
      document.getElementById('initial-message')?.classList.add('hidden');
    }

    let pagefind;
    let debounceTimer;

    async function initSearch() {
      try {
        // Pagefindを動的にインポート
        pagefind = await import('/pagefind/pagefind.js').catch(() => {
          handlePagefindError();
          return null;
        });

        if (!pagefind) {
          return;
        }

        const searchInput = document.getElementById('search-input');
        const clearButton = document.getElementById('clear-button');
        const searchStatus = document.getElementById('search-status');
        const searchResults = document.getElementById('search-results');
        const initialMessage = document.getElementById('initial-message');

        // URLパラメータから検索クエリを取得
        const urlParams = new URLSearchParams(window.location.search);
        const initialQuery = urlParams.get('q');
        if (initialQuery) {
          searchInput.value = initialQuery;
          performSearch(initialQuery);
        }

        // 検索入力イベント
        searchInput.addEventListener('input', (e) => {
          const query = e.target.value.trim();

          // クリアボタンの表示/非表示
          if (query) {
            clearButton.classList.remove('hidden');
          } else {
            clearButton.classList.add('hidden');
          }

          // デバウンス処理
          clearTimeout(debounceTimer);
          debounceTimer = setTimeout(() => {
            if (query) {
              performSearch(query);
              // URLを更新
              const url = new URL(window.location);
              url.searchParams.set('q', query);
              window.history.replaceState({}, '', url);
            } else {
              clearResults();
            }
          }, 300);
        });

        // クリアボタン
        clearButton.addEventListener('click', () => {
          searchInput.value = '';
          clearButton.classList.add('hidden');
          clearResults();
          searchInput.focus();
          // URLパラメータを削除
          const url = new URL(window.location);
          url.searchParams.delete('q');
          window.history.replaceState({}, '', url);
        });

        async function performSearch(query) {
          initialMessage.classList.add('hidden');
          searchStatus.classList.remove('hidden');
          searchStatus.textContent = '検索中...';

          try {
            const results = await pagefind.search(query);

            if (results.results.length === 0) {
              searchStatus.textContent = `「${query}」の検索結果が見つかりませんでした`;
              searchResults.innerHTML = '';
              return;
            }

            searchStatus.textContent = `「${query}」の検索結果 ${results.results.length} 件`;

            // 検索結果を表示（最大20件）
            const resultsToShow = results.results.slice(0, 20);
            const resultsData = await Promise.all(
              resultsToShow.map(r => r.data())
            );

            searchResults.innerHTML = resultsData.map(result => `
              <article class="p-6 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:shadow-lg transition-shadow duration-200">
                <a href="${result.url}" class="block group">
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 mb-2">
                    ${result.meta?.title || 'タイトルなし'}
                  </h3>
                  <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">
                    ${result.excerpt || result.meta?.description || ''}
                  </p>
                  <div class="flex items-center text-xs text-gray-500 dark:text-gray-500">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                    </svg>
                    ${result.url}
                  </div>
                </a>
              </article>
            `).join('');

          } catch (error) {
            searchStatus.textContent = '検索中にエラーが発生しました';
            searchResults.innerHTML = '';
          }
        }

        function clearResults() {
          searchStatus.classList.add('hidden');
          searchResults.innerHTML = '';
          initialMessage.classList.remove('hidden');
        }

      } catch (error) {
        handlePagefindError();
      }
    }

    // ページ読み込み完了後に初期化
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSearch);
    } else {
      initSearch();
    }
  </script>
</Layout>
