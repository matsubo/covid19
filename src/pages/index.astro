---
import BaseLayout from "@/layouts/base.astro";
import ArticleCard from "@/components/covid19/ArticleCard.astro";
import { covid19Handler } from "@/lib/handlers/covid19";
import { getAllPrefectures, getPrefectureName } from "@/lib/utils/prefecture";

// 統計情報を取得
const statistics = await covid19Handler.statistics();

// 最新記事を取得
const latestArticles = await covid19Handler.latestArticles(6);

// 都道府県別の記事数を取得（全件）
const allPrefectures = statistics.prefectureCount;

const meta = {
  title: "新型コロナウイルス新規陽性者数の遷移グラフ",
  metaTitle: "新型コロナウイルス新規陽性者数の遷移グラフ",
  description: "各都道府県が提供しているオープンデータをグラフ化",
  type: "website" as const,
  ogImage: "/images/2022/09/gruff20220926-1-r4c6mc.png",
  ogImageAlt: "新型コロナウイルス新規陽性者数の遷移グラフ",
};
---

<BaseLayout entry={{ meta }}>
  <!-- Hero セクション -->
  <div class="relative overflow-hidden bg-gradient-to-br from-indigo-50 via-white to-purple-50 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900">
    <!-- 背景画像 -->
    <div class="absolute inset-0 bg-cover bg-center opacity-10 dark:opacity-5" style="background-image: url('/images/2022/09/gruff20220926-1-r4c6mc.png');"></div>
    
    <!-- グリッドオーバーレイ -->
    <div class="absolute inset-0 bg-grid-slate-100 [mask-image:linear-gradient(0deg,white,rgba(255,255,255,0.6))] dark:bg-grid-slate-700/25 dark:[mask-image:linear-gradient(0deg,rgba(255,255,255,0.1),rgba(255,255,255,0.5))]"></div>
    
    <div class="container relative mx-auto px-4 py-20 md:py-32">
      <div class="max-w-4xl mx-auto text-center">
        <!-- メインタイトル -->
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6 animate-fade-in-up opacity-0">
          <span class="gradient-text">新型コロナウイルス</span>
          <br />
          <span class="text-gray-800 dark:text-white">新規陽性者数の遷移グラフ</span>
        </h1>
        
        <!-- サブタイトル -->
        <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 mb-12 animate-fade-in-up opacity-0 stagger-1">
          各都道府県が提供しているオープンデータをグラフ化
        </p>

        <!-- 統計情報カード -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6 mb-12 animate-fade-in-up opacity-0 stagger-2">
          <div class="bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl p-6 shadow-lg border border-gray-200 dark:border-gray-700">
            <div class="text-sm text-gray-500 dark:text-gray-400 mb-2">総記事数</div>
            <div class="text-3xl md:text-4xl font-bold text-indigo-600 dark:text-indigo-400">
              {statistics.totalArticles.toLocaleString()}
            </div>
          </div>
          <div class="bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl p-6 shadow-lg border border-gray-200 dark:border-gray-700">
            <div class="text-sm text-gray-500 dark:text-gray-400 mb-2">都道府県</div>
            <div class="text-3xl md:text-4xl font-bold text-purple-600 dark:text-purple-400">
              {allPrefectures.length}
            </div>
          </div>
          <div class="col-span-2 md:col-span-1 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl p-6 shadow-lg border border-gray-200 dark:border-gray-700">
            <div class="text-sm text-gray-500 dark:text-gray-400 mb-2">データ期間</div>
            <div class="text-xl md:text-2xl font-bold text-pink-600 dark:text-pink-400">
              2020 - 2022
            </div>
          </div>
        </div>

        <!-- 更新停止のお知らせ -->
        <div class="alert bg-blue-50 dark:bg-blue-900/30 border-2 border-blue-200 dark:border-blue-700 shadow-xl animate-fade-in-up opacity-0 stagger-3">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-blue-600 dark:stroke-blue-400 shrink-0 w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div class="text-left">
            <h3 class="font-bold text-blue-900 dark:text-blue-200">サイトの更新を停止しています</h3>
            <div class="text-sm text-blue-800 dark:text-blue-300">
              このサイトは2022年10月をもって更新を停止しました。
              <a href="/history" class="font-semibold hover:underline decoration-2 underline-offset-2">詳細はこちら →</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 装飾的な要素 -->
    <div class="absolute top-0 right-0 w-72 h-72 bg-purple-300 dark:bg-purple-600 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-3xl opacity-20 animate-blob"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 bg-indigo-300 dark:bg-indigo-600 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-3xl opacity-20 animate-blob animation-delay-2000"></div>
  </div>

  <div class="container mx-auto px-4">
    <!-- 都道府県一覧セクション -->
    <section class="py-20">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold mb-4">
          <span class="gradient-text">都道府県別</span>データ
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400">
          お住まいの地域のデータをご確認ください
        </p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 max-w-7xl mx-auto">
        {allPrefectures.map((pref, index) => {
          const prefectureName = getPrefectureName(pref.prefecture);
          const delayClass = `stagger-${Math.min(index % 6 + 1, 6)}`;

          return (
            <a
              href={`/prefecture/${pref.prefecture}`}
              class={`prefecture-card bg-white dark:bg-gray-800 rounded-xl shadow-lg p-6 text-center border border-gray-100 dark:border-gray-700 animate-scale-in opacity-0 ${delayClass}`}
            >
              <h3 class="text-lg font-bold mb-3 text-gray-800 dark:text-white">{prefectureName}</h3>
              <div class="mb-2">
                <div class="text-4xl font-bold bg-gradient-to-r from-indigo-600 to-purple-600 dark:from-indigo-400 dark:to-purple-400 bg-clip-text text-transparent">
                  {pref.count.toLocaleString()}
                </div>
              </div>
              <p class="text-sm text-gray-500 dark:text-gray-400">件の記事</p>
              <div class="mt-4 h-1 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full transform scale-x-0 transition-transform duration-300 group-hover:scale-x-100"></div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- 最新記事セクション -->
    <section class="py-20 bg-gradient-to-b from-transparent to-gray-50 dark:to-gray-900/50">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-4xl md:text-5xl font-bold mb-2">
            <span class="gradient-text">最新</span>の記事
          </h2>
          <p class="text-gray-600 dark:text-gray-400">直近の更新情報をチェック</p>
        </div>
        <a 
          href="/archives/1" 
          class="btn btn-primary btn-lg shadow-lg hover:shadow-xl transform hover:scale-105 transition-all duration-300"
        >
          すべての記事を見る
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {latestArticles.map((article, index) => {
          const delayClass = `stagger-${Math.min(index % 6 + 1, 6)}`;
          return (
            <div class={`animate-fade-in-up opacity-0 ${delayClass}`}>
              <ArticleCard article={article} />
            </div>
          );
        })}
      </div>
    </section>

    <!-- CTAセクション -->
    <section class="py-20">
      <div class="max-w-4xl mx-auto text-center bg-gradient-to-br from-indigo-600 to-purple-600 dark:from-indigo-500 dark:to-purple-500 rounded-3xl p-12 shadow-2xl text-white">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          データをもっと詳しく見る
        </h2>
        <p class="text-lg mb-8 text-indigo-100">
          各都道府県の詳細なグラフと統計データを確認できます
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/archives/1" 
            class="btn btn-lg bg-white text-indigo-600 hover:bg-gray-100 border-none shadow-lg transform hover:scale-105 transition-all duration-300"
          >
            全記事を見る
          </a>
          <a 
            href="/history" 
            class="btn btn-lg btn-outline border-2 border-white text-white hover:bg-white hover:text-indigo-600 shadow-lg transform hover:scale-105 transition-all duration-300"
          >
            サイトについて
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  @keyframes blob {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(30px, -50px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
  }

  .animate-blob {
    animation: blob 7s infinite;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .bg-grid-slate-100 {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' width='32' height='32' fill='none' stroke='rgb(148 163 184 / 0.05)'%3e%3cpath d='M0 .5H31.5V32'/%3e%3c/svg%3e");
  }

  .dark .bg-grid-slate-700\/25 {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' width='32' height='32' fill='none' stroke='rgb(51 65 85 / 0.25)'%3e%3cpath d='M0 .5H31.5V32'/%3e%3c/svg%3e");
  }
</style>
