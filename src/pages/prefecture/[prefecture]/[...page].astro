---
import BaseLayout from "@/layouts/base.astro";
import ArticleCard from "@/components/covid19/ArticleCard.astro";
import Pagination from "@/components/shared/pagination.astro";
import { covid19Handler } from "@/lib/handlers/covid19";
import { getPrefectureName, isValidPrefecture, getAllPrefectures } from "@/lib/utils/prefecture";
import { SITE } from "@/lib/config";

export async function getStaticPaths() {
  const prefectures = getAllPrefectures();
  const paths = [];

  for (const prefecture of prefectures) {
    const articles = await covid19Handler.articlesByPrefecture(prefecture.slug);
    const totalPages = Math.ceil(articles.length / SITE.postsPerPage);

    // 全てのページのパスを生成
    for (let i = 1; i <= totalPages; i++) {
      const start = (i - 1) * SITE.postsPerPage;
      const end = start + SITE.postsPerPage;

      // /prefecture/tokyo と /prefecture/tokyo/1 の両方を生成（i === 1の場合）
      if (i === 1) {
        paths.push({
          params: {
            prefecture: prefecture.slug,
            page: undefined,
          },
          props: {
            articles: articles.slice(start, end),
            currentPage: i,
            totalPages,
            totalArticles: articles.length,
            prefectureSlug: prefecture.slug,
            prefectureName: prefecture.name,
          },
        });
      }
      
      paths.push({
        params: {
          prefecture: prefecture.slug,
          page: i.toString(),
        },
        props: {
          articles: articles.slice(start, end),
          currentPage: i,
          totalPages,
          totalArticles: articles.length,
          prefectureSlug: prefecture.slug,
          prefectureName: prefecture.name,
        },
      });
    }
  }

  return paths;
}

const {
  articles,
  currentPage,
  totalPages,
  totalArticles,
  prefectureSlug,
  prefectureName,
} = Astro.props;

// メタ情報
const meta = {
  title: `${prefectureName}の新型コロナウイルス新規陽性者数グラフ`,
  description: `${prefectureName}の新型コロナウイルス新規陽性者数の推移グラフ一覧（${totalArticles}件のグラフ）`,
  type: "website" as const,
};

// ページネーション用の情報
const baseUrl = `/prefecture/${prefectureSlug}`;
const currentUrl = currentPage === 1 
  ? `/prefecture/${prefectureSlug}` 
  : `/prefecture/${prefectureSlug}/${currentPage}`;
const prevUrl = currentPage > 1 
  ? (currentPage === 2 ? `/prefecture/${prefectureSlug}` : `/prefecture/${prefectureSlug}/${currentPage - 1}`)
  : undefined;
const nextUrl = currentPage < totalPages ? `/prefecture/${prefectureSlug}/${currentPage + 1}` : undefined;
const lastUrl = `/prefecture/${prefectureSlug}/${totalPages}`;
---

<BaseLayout entry={{ meta }}>
  <div class="container mx-auto px-4 py-12">
    <!-- ヘッダー -->
    <header class="mb-12 text-center">
      <nav class="breadcrumbs text-sm mb-4 justify-center">
        <ul>
          <li><a href="/">ホーム</a></li>
          <li>{prefectureName}</li>
        </ul>
      </nav>
      <h1 class="text-5xl font-bold mb-4">{prefectureName}</h1>
      <p class="text-xl text-gray-600 dark:text-gray-300">
        新型コロナウイルス新規陽性者数の推移グラフ
      </p>
      <p class="text-lg mt-2">
        全{totalArticles}件のグラフ
      </p>
    </header>

    <!-- 記事一覧 -->
    {articles.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {articles.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-gray-500 dark:text-gray-400 text-lg">
          グラフがありません
        </p>
      </div>
    )}

    <!-- ページネーション -->
    <Pagination
      length={totalPages}
      currentUrl={currentUrl}
      currentPage={currentPage}
      baseUrl={baseUrl}
      prevUrl={prevUrl}
      nextUrl={nextUrl}
      lastUrl={lastUrl}
    />
  </div>
</BaseLayout>
